{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler", // no idea what this this does AI told to paste
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["bun-types"],
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true, //  idk what is this AI told to paste it
    "ignoreDeprecations": "6.0" // to shut up idiotic baseUrl
  }
}